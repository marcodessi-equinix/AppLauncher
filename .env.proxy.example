# AppLauncher proxy compose example
# Copy to .env when using: docker compose -f docker-compose.proxy.yml up -d --build

# -- Required ------------------------------------------------------
# A random secret used to sign JWT tokens (min 32 chars).
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Admin login password.
ADMIN_PASSWORD=

# Public URL served by your reverse proxy.
# Required so the backend accepts the external origin for authenticated writes.
FRONTEND_URL=https://applauncher.example.com

# Existing external Docker/Podman network shared with Nginx Proxy Manager.
# Example: nginx-proxy-manager_default
NPM_NETWORK=

# Internal DNS alias that Nginx Proxy Manager should target on that network.
PROXY_FRONTEND_ALIAS=applauncher-frontend

# Reverse proxy terminates TLS, so cookies should always be secure.
COOKIE_SECURE=true

# No APP_PORT is needed here because docker-compose.proxy.yml does not publish host ports.

# Optional: override runtime storage paths.
# DATABASE_PATH=/app/data/applauncher.db
# UPLOAD_PATH=/app/uploads/icons

# -- Required build metadata for deployment ------------------------
BUILD_VERSION=2.1.0
BUILD_DATE=2026-01-01
GIT_SHA=dev

# Optional CI metadata
# BUILD_TIME=14:30:00
# BUILD_NUMBER=123
